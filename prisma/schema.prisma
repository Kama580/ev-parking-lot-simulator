generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model SimulationConfig {
  id                String   @id @default(uuid())
  name              String
  numChargers       Int
  arrivalMultiplier Float
  carConsumption    Float
  chargerPowerKW    Float
  results           SimulationResult[]
  createdAt         DateTime @default(now())
}

model SimulationResult {
  id                    String   @id @default(uuid())
  totalEnergykWh        Float
  theoreticalMaxPowerKW Float
  actualMaxPowerKW      Float
  concurrencyFactor     Float
  chargingEvents        Int
  configId              String
  config                SimulationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
}