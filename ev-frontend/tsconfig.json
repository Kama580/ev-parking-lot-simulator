{
	"compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
		"target": "ESNext",
		"useDefineForClassFields": true,
		"lib": ["ESNext", "DOM"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"strict": true,
		"jsx": "react-jsx",
		"sourceMap": true,
		"resolveJsonModule": true,
		"esModuleInterop": true
	},
	"include": ["src"]
}
