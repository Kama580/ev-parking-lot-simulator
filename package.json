{
  "name": "reonic-simulator",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "npm run build && node dist/index.js",
    "db:migrate": "prisma migrate dev --config prisma/prisma.config.ts",
    "db:generate": "prisma generate --config prisma/prisma.config.ts",
    "db:seed": "prisma db seed --config prisma/prisma.config.ts"
  },
  "keywords": [],
  "author": "Kama Lee-Tal",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.7.0",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
